{
  "name": "vocab-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config frontend/vite.config.ts",
    "build": "vite build --config frontend/vite.config.ts",
    "preview": "vite preview --config frontend/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "cf:dev": "wrangler pages dev dist",
    "cf:deploy": "wrangler pages deploy dist",
    "db:migrate:local": "wrangler d1 migrations apply vocab-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply vocab-db --remote"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260303.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.8.2",
    "vite": "^6.3.0",
    "vitest": "^4.1.4",
    "wrangler": "^4.8.0"
  }
}
